      "陕西上市公司控制或参股项目公司发生股权转让、引资或挂牌处置"
    ],
    "excludeFromMainAmount": [
      "纯融资事件",
      "价格待定的意向协议",
      "停牌筹划但未披露方案",
      "已终止且未披露最终交易作价的重组"
    ]
  },
  "companyDimensions": [
    "已上市公司",
    "拟上市与辅导企业",
