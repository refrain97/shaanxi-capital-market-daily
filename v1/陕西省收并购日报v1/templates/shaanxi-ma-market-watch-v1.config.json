    {
      "name": "已签协议/董事会通过",
      "countInDisclosedAmount": true
    },
    {
      "name": "挂牌/推进中",
      "countInDisclosedAmount": true
    },
    {
      "name": "意向/筹划/停牌",
      "countInDisclosedAmount": false
    },
    {
      "name": "终止",
      "countInDisclosedAmount": false
    }
